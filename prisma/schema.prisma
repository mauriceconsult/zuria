generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id         String      @id @default(uuid())
  userId     String
  name       String
  country    String      @default("UG")
  currency   String      @default("UGX")
  momoPhone  String?
  phone      String?
  billboards Billboard[] @relation("ShopToBillboard")
  categories Category[]  @relation("ShopToCategory")
  sizes      Size[]      @relation("ShopToSize")
  colors     Color[]     @relation("ShopToColor")
  products   Product[]   @relation("ShopToProduct")
  orders     Order[]     @relation("ShopToOrder")
  refundRequests RefundRequest[] @relation("ShopToRefundRequest")

  latitude  Float?
  longitude Float?
  address   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Billboard {
  id         String     @id @default(uuid())
  shopId     String
  shop       Shop       @relation("ShopToBillboard", fields: [shopId], references: [id])
  label      String
  imageUrl   String
  categories Category[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
}

model Category {
  id          String    @id @default(uuid())
  products    Product[] @relation("CategoryToProduct")
  shopId      String
  shop        Shop      @relation("ShopToCategory", fields: [shopId], references: [id])
  billboardId String
  billboard   Billboard @relation(fields: [billboardId], references: [id])
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([shopId])
  @@index([billboardId])
}

model Size {
  id        String    @id @default(uuid())
  shopId    String
  shop      Shop      @relation("ShopToSize", fields: [shopId], references: [id])
  products  Product[]
  name      String
  value     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([shopId])
}

model Color {
  id     String @id @default(uuid())
  shopId String
  shop   Shop   @relation("ShopToColor", fields: [shopId], references: [id])

  name      String
  value     String
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([shopId])
}

model Product {
  id         String      @id @default(uuid())
  shopId     String
  shop       Shop        @relation("ShopToProduct", fields: [shopId], references: [id])
  categoryId String
  category   Category    @relation("CategoryToProduct", fields: [categoryId], references: [id])
  name       String
  price      Decimal
  isFeatured Boolean     @default(false)
  isArchived Boolean     @default(false)
  sizeId     String
  size       Size        @relation(fields: [sizeId], references: [id])
  colorId    String
  color      Color       @relation(fields: [colorId], references: [id])
  images     Image[]
  orderItems OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([shopId])
  @@index([categoryId])
  @@index([sizeId])
  @@index([colorId])
}

model Image {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model Order {
  id         String      @id @default(uuid())
  shopId     String
  shop       Shop        @relation("ShopToOrder", fields: [shopId], references: [id])
  orderItems OrderItem[]
  isPaid     Boolean     @default(false)
  phone      String      @default("")
  address    String      @default("")

  platformFee Decimal?
  shopPayout  Decimal?

  deliveredAt     DateTime?
  refundRequest   RefundRequest?
  deliveryLat         Float?
  deliveryLng         Float?

  // Payment
  paymentMethod String  @default("stripe") // "stripe" | "mobile_money"
  paymentRef    String? // stripe session id or momo referenceId
  paymentStatus String  @default("pending") // "pending" | "completed" | "failed"

  // Delivery
  deliveryMethod      String? // "uber_direct" | "self_pickup" | "rider"
  deliveryQuoteId     String?
  deliveryStatus      String   @default("pending") // "pending" | "dispatched" | "delivered"
  deliveryRef         String? // uber direct delivery id or rider momo referenceId
  deliveryCost        Decimal?
  deliveryProvider    String? // "uber_direct" | "glovo" | "flat_rate" etc.
  deliveryTrackingUrl String? // for customer tracking

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
}
model RefundRequest {
  id              String   @id @default(uuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id])
  shopId          String
  shop            Shop     @relation("ShopToRefundRequest", fields: [shopId], references: [id])
  buyerPhone      String
  buyerEmail      String?
  reason          String
  evidence        String[] // Cloudinary image URLs
  status          String   @default("pending")
  // pending → under_review → approved → rejected → refunded
  sellerResponse  String?
  adminNotes      String?
  requestedAt     DateTime @default(now())
  resolvedAt      DateTime?
  refundedAt      DateTime?
  expiresAt       DateTime // requestedAt + 48 hours
  
  @@index([shopId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}
